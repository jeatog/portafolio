---
import '@/styles/fonts.css';
import '@/styles/global.css';

interface Props {
  titulo: string;
  descripcion: string;
  ogImagen?: string;
  ogTipo?: string;
  urlCanonica?: string;
}

const {
  titulo,
  descripcion,
  ogImagen = '/og-default.png',
  ogTipo = 'website',
  urlCanonica,
} = Astro.props;

const canonica = urlCanonica || Astro.url.href;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={canonica} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogTipo} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={new URL(ogImagen, Astro.site)} />
    <meta property="og:url" content={canonica} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={new URL(ogImagen, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="jeatog" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="theme-color" content="#232136" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#faf4ed" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />

    <!-- Anti-FOUC: aplicar tema e idioma antes del primer render -->
    <script is:inline>
      (function() {
        var tema = localStorage.getItem('tema');
        if (tema === 'light' || (!tema && window.matchMedia('(prefers-color-scheme: light)').matches)) {
          document.documentElement.classList.add('light');
        }
        var idioma = localStorage.getItem('idioma');
        if (idioma) {
          document.documentElement.lang = idioma;
        }
      })();
    </script>
  </head>
  <body class="relative">
    <div class="fondo-gradiente absolute top-0 bottom-0 z-[-2] min-h-screen w-full"></div>
    <slot />
  </body>
</html>
