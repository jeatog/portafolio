---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Hero from '@/components/hero/Hero.astro';
import TechStack from '@/components/stack/TechStack.astro';
import Experiencia from '@/components/experiencia/Experiencia.astro';
import ProyectoGrid from '@/components/proyectos/ProyectoGrid.astro';
import Educacion from '@/components/educacion/Educacion.astro';
import Footer from '@/components/layout/Footer.astro';
import { textos } from '@/utils/textos';
---

<BaseLayout
  titulo={textos.sitio.titulo}
  descripcion={textos.sitio.descripcion}
>
  <Header />
  <main class="px-4">
    <Hero />
    <div class="mx-auto max-w-4xl space-y-24">
      <TechStack />
      <Experiencia />
      <ProyectoGrid />
      <Educacion />
    </div>
  </main>
  <Footer />
</BaseLayout>
