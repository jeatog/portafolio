---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Hero from '@/components/hero/Hero.astro';
import SobreMi from '@/components/sobre-mi/SobreMi.astro';
import TechStack from '@/components/stack/TechStack.astro';
import ProyectoGrid from '@/components/proyectos/ProyectoGrid.astro';
import Footer from '@/components/layout/Footer.astro';
import { textos } from '@/utils/textos';
---

<BaseLayout
  titulo={textos.sitio.titulo}
  descripcion={textos.sitio.descripcion}
>
  <Header />
  <main>
    <Hero />
    <SobreMi />
    <TechStack />
    <ProyectoGrid />
  </main>
  <Footer />
</BaseLayout>
