---
import { textos } from '@/utils/textos';
import ExperienciaItem from './ExperienciaItem.astro';
---

<section id="experiencia">
  <h2 class="flex items-center mb-6 text-3xl font-semibold gap-x-3">
    <svg class="size-7" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
      <path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z"></path>
      <path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"></path>
      <path d="M12 12l0 .01"></path>
      <path d="M3 13a20 20 0 0 0 18 0"></path>
    </svg>
    <span data-i18n="experiencia.titulo">{textos.experiencia.titulo}</span>
  </h2>
  <ol class="relative mt-16">
    {textos.experiencia.items.map((exp, i) => (
      <li>
        <ExperienciaItem {...exp} indice={i} />
      </li>
    ))}
  </ol>
</section>
