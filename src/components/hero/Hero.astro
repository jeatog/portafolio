---
import { Image } from 'astro:assets';
import foto from '@/assets/foto.png';
import { textos } from '@/utils/textos';
import MarqueeStack from './MarqueeStack.astro';
---

<section id="hero" class="relative flex flex-col items-center justify-center px-4 py-24 md:py-36 text-center overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[80%] aspect-[709/1391] opacity-[0.15] blur-sm"
  >
    <div class="logo-hero h-full w-full"></div>
  </div>
  <div class="relative max-w-2xl space-y-6">
    <div class="relative mx-auto size-24">
      <span class="absolute inset-[-4px] rounded-full animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,var(--color-foam)_0%,var(--color-overlay)_50%,var(--color-foam)_100%)]"></span>
      <Image
        src={foto}
        alt={textos.hero.nombre}
        width={96}
        height={96}
        class="relative size-24 rounded-full object-cover"
      />
    </div>
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl">
      {textos.hero.nombre}
    </h1>
    <p class="text-xl font-semibold text-[var(--color-iris)] sm:text-2xl">
      {textos.hero.rol}
    </p>
    <p class="text-lg text-[var(--color-subtle)] sm:text-xl">
      {textos.hero.tagline}
    </p>

    <MarqueeStack />

    <div class="flex flex-wrap items-center justify-center gap-4 pt-4">
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-iris)] px-6 py-3 font-semibold text-[var(--color-base)] transition-opacity hover:opacity-90"
      >
        <svg class="size-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M7 8l-4 4l4 4"></path>
          <path d="M17 8l4 4l-4 4"></path>
          <path d="M14 4l-4 16"></path>
        </svg>
        {textos.hero.ctaProyectos}
      </a>
      <a
        href={`mailto:${textos.sociales.correo}`}
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-highlight-high)] px-6 py-3 font-semibold text-[var(--color-text)] transition-colors hover:border-[var(--color-iris)] hover:text-[var(--color-iris)]"
      >
        <svg class="size-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M12 18h-7a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v7.5"></path>
          <path d="M3 6l9 6l9 -6"></path>
          <path d="M15 18h6"></path>
          <path d="M18 15l3 3l-3 3"></path>
        </svg>
        {textos.hero.ctaContacto}
      </a>
    </div>

    <div class="flex items-center justify-center gap-5 pt-2">
      <a
        href={textos.sociales.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-[var(--color-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        <svg class="size-6" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z" transform="scale(64)" />
        </svg>
      </a>
      <a
        href={textos.sociales.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-[var(--color-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        <svg class="size-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 1 1 0-4.125 2.062 2.062 0 0 1 0 4.125ZM6.92 20.452H3.753V9H6.92v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z" />
        </svg>
      </a>
    </div>
  </div>
</section>
