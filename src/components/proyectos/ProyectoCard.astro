---
import ProyectoBadge from './ProyectoBadge.astro';
import EnlaceBoton from './EnlaceBoton.astro';
import { textos } from '@/utils/textos';

interface Props {
  titulo: string;
  descripcion: string;
  imagen: string;
  tags: string[];
  github?: string;
  enlace?: string;
}

const { titulo, descripcion, imagen, tags, github, enlace } = Astro.props;
---

<article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 overflow-clip rounded-xl transition duration-500 ease-in-out transform shadow-xl border border-[var(--color-highlight-med)] md:group-hover:-translate-y-1 md:group-hover:shadow-2xl hover:border-[var(--color-highlight-high)]">
      <img
        alt={titulo}
        class="object-cover object-top w-full transition duration-500 md:group-hover:scale-105"
        loading="lazy"
        src={imagen}
      />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-bold text-[var(--color-rose)]">
      {titulo}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row flex-wrap mb-2 gap-2">
        {tags.map((tag) => (
          <li>
            <ProyectoBadge nombre={tag} />
          </li>
        ))}
      </ul>

      <p class="mt-2 text-[var(--color-subtle)]">{descripcion}</p>

      <footer class="flex items-end justify-start mt-4 gap-x-4">
        {github && (
          <EnlaceBoton href={github}>
            <svg class="size-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path>
            </svg>
            {textos.proyectos.codigo}
          </EnlaceBoton>
        )}
        {enlace && (
          <EnlaceBoton href={enlace}>
            <svg class="size-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            {textos.proyectos.preview}
          </EnlaceBoton>
        )}
      </footer>
    </div>
  </div>
</article>
