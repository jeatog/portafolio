---
import Nav from './Nav.astro';
---

<header class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2">
  <Nav />
</header>

<script>
  const secciones = document.querySelectorAll('section');
  const elementosNav = document.querySelectorAll('header nav a');

  const callback = (entradas: IntersectionObserverEntry[]) => {
    entradas.forEach((entrada) => {
      if (entrada.isIntersecting) {
        elementosNav.forEach((el) => {
          const esActivo = el.getAttribute('aria-label') === entrada.target.id;
          (el as HTMLElement).style.color = esActivo
            ? 'var(--color-gold)'
            : '';
        });
      }
    });
  };

  const observador = new IntersectionObserver(callback, {
    root: null,
    rootMargin: '-20% 0px -60% 0px',
    threshold: 0,
  });

  secciones.forEach((seccion) => {
    observador.observe(seccion);
  });
</script>
